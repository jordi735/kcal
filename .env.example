PORT=3000
DATABASE_PATH=./data/app.db
POSTMARK_SERVER_TOKEN=PM-replace-with-real-token
POSTMARK_FROM=noreply@your-verified-domain.com
SESSION_EXPIRY_DAYS=90
# In dev, login codes are also logged at debug level — set LOG_LEVEL=debug to
# skip the inbox round-trip and grab the code from the server terminal.
LOGIN_CODE_EXPIRY_MINUTES=15
AI_SCAN_DAILY_CAP=50
LOG_LEVEL=info
# Test-only. Never set in production. Disables the Postmark email call and
# exposes GET /auth/test/last-code/:email so Playwright can read login codes.
TEST_MODE=false
# Comma-separated IP allowlist for /debug. Unset/empty → every caller is
# denied (fail-closed). Add your dev/admin IPs to enable the page locally
# (e.g. 127.0.0.1) or in prod (your home/office IP). 404s non-matching callers.
DEBUG_ALLOW_IPS=
# Express `trust proxy` setting. Default 'loopback'. Set to '1' (or your
# specific config) when behind a reverse proxy so req.ip resolves to the
# real client and not the proxy hop.
TRUST_PROXY=loopback
